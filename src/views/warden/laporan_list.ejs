<%- include('../partials/header', { title }) %>

<div class="page-header">
  <div class="eyebrow">Laporan</div>
  <h1>Laporan Masuk</h1>
  <p>Laporan hasil perhitungan TOPSIS yang diteruskan oleh Koordinator Wali.</p>
</div>

<% if (laporan.length === 0) { %>
  <div class="empty-state"><h3>Belum ada laporan masuk</h3></div>
<% } else { %>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Judul</th><th>Dari</th><th>Periode</th><th>Status</th><th>Tanggal</th><th></th></tr></thead>
      <tbody>
        <% laporan.forEach(d => { %>
          <tr>
            <td><%= d.judul %></td>
            <td><%= d.dari_nama %></td>
            <td><%= d.nama_periode || '—' %></td>
            <td><span class="badge <%= d.status === 'diterima' ? 'badge-success' : 'badge-accent' %>"><%= d.status %></span></td>
            <td><%= d.created_at %></td>
            <td>
              <a href="/warden/laporan/<%= d.id %>/unduh" class="btn btn-outline btn-sm">Unduh</a>
              <% if (d.status !== 'diterima') { %>
                <form action="/warden/laporan/<%= d.id %>/terima" method="POST" style="display:inline">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn btn-primary btn-sm">Tandai Diterima</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
