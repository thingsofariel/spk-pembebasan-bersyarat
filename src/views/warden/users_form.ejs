<%- include('../partials/header', { title }) %>

<div class="page-header">
  <div class="eyebrow">Manajemen Pengguna</div>
  <h1><%= user ? 'Ubah Pengguna' : 'Tambah Pengguna' %></h1>
</div>

<div class="card" style="max-width:560px;">
  <form action="<%= user ? `/warden/users/${user.id}/edit` : '/warden/users/new' %>" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="field">
      <label for="nama">Nama Lengkap</label>
      <input type="text" id="nama" name="nama" required value="<%= user ? user.nama : '' %>" />
    </div>
    <div class="field">
      <label for="username">Username</label>
      <input type="text" id="username" value="<%= user ? user.username : '' %>" <%= user ? 'disabled' : '' %> <%= user ? '' : 'name="username" required' %> />
      <% if (user) { %><span class="hint">Username tidak dapat diubah.</span><% } %>
    </div>
    <div class="field">
      <label for="password"><%= user ? 'Password Baru (opsional)' : 'Password' %></label>
      <div class="password-field-wrap">
        <input type="password" id="password" name="password" <%= user ? 'minlength="6"' : 'required minlength="6"' %> />
        <button type="button" class="password-toggle" aria-label="Tampilkan password">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8Z"/><circle cx="12" cy="12" r="3"/></svg>
        </button>
      </div>
      <% if (user) { %><span class="hint">Kosongkan jika tidak ingin mengganti password.</span><% } %>
    </div>
    <div class="field">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= user ? (user.email || '') : '' %>" />
    </div>
    <div class="field">
      <label for="role">Peran</label>
      <select id="role" name="role" <%= user && user.id === currentUser.id ? 'disabled' : '' %>
        onchange="document.getElementById('koordinatorField').style.display = this.value === 'wali' ? 'flex' : 'none';">
        <option value="koordinator_wali" <%= user && user.role === 'koordinator_wali' ? 'selected' : '' %>>Koordinator Wali Pemasyarakatan</option>
        <option value="wali" <%= user && user.role === 'wali' ? 'selected' : '' %>>Wali Pemasyarakatan</option>
        <option value="kepala_lapas" <%= user && user.role === 'kepala_lapas' ? 'selected' : '' %>>Kepala Lapas</option>
      </select>
      <% if (user && user.id === currentUser.id) { %>
        <span class="hint">Anda tidak dapat mengubah peran akun Anda sendiri.</span>
        <input type="hidden" name="role" value="<%= user.role %>" />
      <% } %>
    </div>
    <div class="field" id="koordinatorField" style="display:<%= user && user.role === 'wali' ? 'flex' : 'none' %>;">
      <label for="koordinator_id">Koordinator (khusus peran Wali)</label>
      <select id="koordinator_id" name="koordinator_id">
        <option value="">— Pilih —</option>
        <% koordinatorList.forEach(k => { %>
          <option value="<%= k.id %>" <%= user && user.koordinator_id === k.id ? 'selected' : '' %>><%= k.nama %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-accent">Simpan</button>
      <a href="/warden/users" class="btn btn-outline">Batal</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
