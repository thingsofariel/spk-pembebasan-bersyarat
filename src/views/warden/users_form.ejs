<%- include('../partials/header', { title }) %>

<div class="page-header">
  <div class="eyebrow">Manajemen Pengguna</div>
  <h1>Tambah Pengguna</h1>
</div>

<div class="card" style="max-width:560px;">
  <form action="/warden/users/new" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="field">
      <label for="nama">Nama Lengkap</label>
      <input type="text" id="nama" name="nama" required />
    </div>
    <div class="field">
      <label for="username">Username</label>
      <input type="text" id="username" name="username" required />
    </div>
    <div class="field">
      <label for="password">Password</label>
      <input type="password" id="password" name="password" required minlength="6" />
    </div>
    <div class="field">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" />
    </div>
    <div class="field">
      <label for="role">Peran</label>
      <select id="role" name="role" onchange="document.getElementById('koordinatorField').style.display = this.value === 'wali' ? 'flex' : 'none';">
        <option value="koordinator_wali">Koordinator Wali Pemasyarakatan</option>
        <option value="wali">Wali Pemasyarakatan</option>
        <option value="kepala_lapas">Kepala Lapas</option>
      </select>
    </div>
    <div class="field" id="koordinatorField">
      <label for="koordinator_id">Koordinator (khusus peran Wali)</label>
      <select id="koordinator_id" name="koordinator_id">
        <option value="">— Pilih —</option>
        <% koordinatorList.forEach(k => { %>
          <option value="<%= k.id %>"><%= k.nama %></option>
        <% }) %>
      </select>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-accent">Simpan</button>
      <a href="/warden/users" class="btn btn-outline">Batal</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
