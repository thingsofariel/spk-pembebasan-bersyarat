<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · SPK Pembebasan Bersyarat</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="login-shell">
  <div class="glass-wrapper">
    <div class="login-card">
      <div class="eyebrow">SPK &middot; Metode TOPSIS</div>
      <h1>Sistem Pendukung Keputusan<br/>Pemberian Hak Pembebasan Bersyarat</h1>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form action="/login" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="field">
          <label for="username">Username</label>
          <input type="text" id="username" name="username" required autofocus />
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required />
        </div>
        <button type="submit" class="btn btn-accent">Masuk</button>
      </form>

      <div class="login-hint">
        Akun demo: <code>kalapas / kalapas123</code> &middot; <code>koordinatorwali / koor123</code> &middot; <code>waliA / wali123</code>
      </div>
    </div>
  </div>
</div>
</body>
</html>
