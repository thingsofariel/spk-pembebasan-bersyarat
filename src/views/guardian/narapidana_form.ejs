<%- include('../partials/header', { title }) %>

<div class="page-header">
  <div class="eyebrow">Data Narapidana</div>
  <h1><%= narapidana ? 'Ubah Data Narapidana' : 'Tambah Narapidana' %></h1>
</div>

<div class="card">
  <form action="<%= narapidana ? `/wali/narapidana/${narapidana.id}/edit` : '/wali/narapidana/new' %>" method="POST">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-grid">
      <div class="field full">
        <label for="nama">Nama Lengkap</label>
        <input type="text" id="nama" name="nama" required value="<%= narapidana ? narapidana.nama : '' %>" />
      </div>
      <div class="field">
        <label for="agama">Agama</label>
        <input type="text" id="agama" name="agama" value="<%= narapidana ? (narapidana.agama || '') : '' %>" />
      </div>
      <div class="field">
        <label for="tempat_lahir">Tempat Lahir</label>
        <input type="text" id="tempat_lahir" name="tempat_lahir" value="<%= narapidana ? (narapidana.tempat_lahir || '') : '' %>" />
      </div>
      <div class="field">
        <label for="tanggal_lahir">Tanggal Lahir</label>
        <input type="date" id="tanggal_lahir" name="tanggal_lahir" value="<%= narapidana ? (narapidana.tanggal_lahir || '') : '' %>" />
      </div>
      <div class="field">
        <label for="umur">Umur</label>
        <input type="number" id="umur" name="umur" min="0" value="<%= narapidana ? (narapidana.umur || '') : '' %>" />
      </div>
      <div class="field full">
        <label for="alamat">Alamat</label>
        <input type="text" id="alamat" name="alamat" value="<%= narapidana ? (narapidana.alamat || '') : '' %>" />
      </div>
      <div class="field">
        <label for="pendidikan_terakhir">Pendidikan Terakhir</label>
        <input type="text" id="pendidikan_terakhir" name="pendidikan_terakhir" value="<%= narapidana ? (narapidana.pendidikan_terakhir || '') : '' %>" />
      </div>
      <div class="field">
        <label for="nomor_ktp">Nomor KTP</label>
        <input type="text" id="nomor_ktp" name="nomor_ktp" value="<%= narapidana ? (narapidana.nomor_ktp || '') : '' %>" />
      </div>
      <div class="field">
        <label for="kategori_register">Kategori Register</label>
        <input type="text" id="kategori_register" name="kategori_register" value="<%= narapidana ? (narapidana.kategori_register || '') : '' %>" />
      </div>
      <div class="field">
        <label for="tindak_pidana_id">Tindak Pidana</label>
        <select id="tindak_pidana_id" name="tindak_pidana_id">
          <option value="">— Pilih —</option>
          <% tindakPidana.forEach(tp => { %>
            <option value="<%= tp.id %>" <%= narapidana && narapidana.tindak_pidana_id === tp.id ? 'selected' : '' %>><%= tp.jenis %></option>
          <% }) %>
        </select>
      </div>
      <div class="field">
        <label for="pekerjaan_semula">Pekerjaan Semula</label>
        <input type="text" id="pekerjaan_semula" name="pekerjaan_semula" value="<%= narapidana ? (narapidana.pekerjaan_semula || '') : '' %>" />
      </div>
      <div class="field">
        <label for="masa_tahanan">Masa Tahanan</label>
        <input type="text" id="masa_tahanan" name="masa_tahanan" placeholder="mis. 18 bulan" value="<%= narapidana ? (narapidana.masa_tahanan || '') : '' %>" />
      </div>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn btn-accent">Simpan</button>
      <a href="/wali/narapidana" class="btn btn-outline">Batal</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
