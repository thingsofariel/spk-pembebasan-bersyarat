<%
  /* variant: 'dark' = for dark backgrounds (sidebar, login card), 'light' = for light backgrounds */
  const logoVariant = typeof variant !== 'undefined' ? variant : 'dark';
%>
<div class="logo-card <%= logoVariant === 'light' ? 'on-light' : '' %>">
    <div class="logo-badge logo-badge-<%= logoVariant %>" style="display: flex; align-items: center; gap: 12px;">
        
        <div class="logo-images" style="display: flex; gap: 8px; align-items: center;">
            <img src="/images/KemenImipas-removebg-preview.png" alt="KemenImipas Logo" style="height: 60px; width: auto;">
            <img src="/images/Pemasyarakatan-removebg-preview.png" alt="Pemasyarakatan Logo" style="height: 60px; width: auto;">
        </div>

        <div class="logo-badge-text">
            <span class="lb-eyebrow">Lapas Kelas IIA</span>
            <span class="lb-title">Kupang</span>
        </div>
        
    </div>
</div>