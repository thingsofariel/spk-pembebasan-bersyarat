<%
  const initials = (profileUser.nama || '?')
    .split(' ')
    .filter(Boolean)
    .slice(0, 2)
    .map((w) => w[0].toUpperCase())
    .join('');
%>
<div class="page-header">
  <div>
    <h1>Profil Saya</h1>
    <p>Informasi akun dan pengaturan password Anda.</p>
  </div>
</div>

<div class="profile-header card">
  <div class="profile-avatar"><%= initials %></div>
  <div>
    <div class="name"><%= profileUser.nama %></div>
    <div class="role"><%= ROLE_LABEL[profileUser.role] %> &middot; <span class="tier-badge" style="position:static; display:inline-block; margin-top:4px;"><%= profileUser.role === 'kepala_lapas' ? 'AKSES LEVEL 0' : profileUser.role === 'koordinator_wali' ? 'AKSES LEVEL 1' : 'AKSES LEVEL 2' %></span></div>
  </div>
</div>

<% if (success) { %>
  <div class="alert alert-success">Perubahan berhasil disimpan.</div>
<% } %>
<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<form action="<%= actionPrefix %>/profil" method="POST" class="card">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

  <h3 style="margin-bottom:16px;">Informasi Akun</h3>
  <div class="form-grid">
    <div class="field">
      <label for="nama">Nama Lengkap</label>
      <input type="text" id="nama" name="nama" value="<%= profileUser.nama %>" required />
    </div>
    <div class="field">
      <label for="username">Username</label>
      <input type="text" id="username" value="<%= profileUser.username %>" disabled />
    </div>
    <div class="field">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= profileUser.email || '' %>" />
    </div>
    <div class="field">
      <label for="role">Peran</label>
      <input type="text" id="role" value="<%= ROLE_LABEL[profileUser.role] %>" disabled />
    </div>
  </div>

  <hr style="border:none; border-top:1px solid var(--color-border); margin:24px 0;" />

  <h3 style="margin-bottom:6px;">Ubah Password</h3>
  <p style="font-size:12.5px; color:var(--color-ink-soft); margin-bottom:16px;">
    Kosongkan bagian ini jika Anda hanya ingin memperbarui nama atau email.
  </p>
  <div class="form-grid">
    <div class="field">
      <label for="current_password">Password Saat Ini</label>
      <div class="password-field-wrap">
        <input type="password" id="current_password" name="current_password" autocomplete="current-password" />
        <button type="button" class="password-toggle" aria-label="Tampilkan password">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8Z"/><circle cx="12" cy="12" r="3"/></svg>
        </button>
      </div>
    </div>
    <div class="field"></div>
    <div class="field">
      <label for="new_password">Password Baru</label>
      <div class="password-field-wrap">
        <input type="password" id="new_password" name="new_password" autocomplete="new-password" minlength="6" />
        <button type="button" class="password-toggle" aria-label="Tampilkan password">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8Z"/><circle cx="12" cy="12" r="3"/></svg>
        </button>
      </div>
      <span class="hint">Minimal 6 karakter.</span>
    </div>
    <div class="field">
      <label for="confirm_password">Konfirmasi Password Baru</label>
      <div class="password-field-wrap">
        <input type="password" id="confirm_password" name="confirm_password" autocomplete="new-password" minlength="6" />
        <button type="button" class="password-toggle" aria-label="Tampilkan password">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8Z"/><circle cx="12" cy="12" r="3"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div style="margin-top:20px;">
    <button type="submit" class="btn btn-accent">Simpan Perubahan</button>
  </div>
</form>
