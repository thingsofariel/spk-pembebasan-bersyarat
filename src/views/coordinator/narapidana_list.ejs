<%- include('../partials/header', { title }) %>

<div class="page-header">
  <div class="eyebrow">Monitor</div>
  <h1>Narapidana di Bawah Koordinasi Anda</h1>
  <p>Tampilan hanya-lihat untuk memantau data narapidana dari seluruh wali binaan Anda.</p>
</div>

<% if (narapidana.length === 0) { %>
  <div class="empty-state">
    <h3>Belum ada data narapidana</h3>
    <p>Data akan muncul di sini setelah wali menambahkan narapidana binaan mereka.</p>
  </div>
<% } else { %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr><th>Nama</th><th>Wali</th><th>Tindak Pidana</th><th>Kategori</th><th>Masa Tahanan</th></tr>
      </thead>
      <tbody>
        <% narapidana.forEach(n => { %>
          <tr>
            <td><strong><%= n.nama %></strong></td>
            <td><%= n.wali_nama %></td>
            <td><%= n.tindak_pidana_jenis || '—' %></td>
            <td><%= n.kategori_register || '—' %></td>
            <td><%= n.masa_tahanan || '—' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
