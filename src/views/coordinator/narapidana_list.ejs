<%- include('../partials/header', { title }) %>

<div class="page-header">
  <div class="eyebrow">LMS &middot; Lapas Management System</div>
  <h1>Data Narapidana</h1>
  <p>Kelola data narapidana untuk seluruh wali binaan di bawah koordinasi Anda.</p>
</div>

<div class="toolbar">
  <span class="helptext"><%= narapidana.length %> narapidana terdaftar</span>
  <div class="toolbar-actions">
    <div class="table-search">
      <%- include('../partials/icon-search') %>
      <input type="text" placeholder="Cari narapidana..." data-table-search="koordinator-narapidana-table" />
    </div>
    <a href="/koordinator/narapidana/new" class="btn btn-accent">+ Tambah Narapidana</a>
  </div>
</div>

<% if (narapidana.length === 0) { %>
  <div class="empty-state">
    <h3>Belum ada data narapidana</h3>
    <p>Tambahkan narapidana dan tetapkan wali pembinanya untuk mulai proses penilaian.</p>
  </div>
<% } else { %>
  <div class="table-wrap">
    <table id="koordinator-narapidana-table">
      <thead>
        <tr>
          <th class="num">No</th><th>Nama</th><th>Wali Pembina</th><th>Tindak Pidana</th><th>Kategori Register</th>
          <th>Masa Tahanan</th><th class="num">Umur</th><th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% narapidana.forEach((n, i) => { %>
          <tr>
            <td class="num"><%= i + 1 %></td>
            <td><strong><%= n.nama %></strong></td>
            <td><%= n.wali_nama %></td>
            <td><%= n.tindak_pidana_jenis || '—' %></td>
            <td><%= n.kategori_register || '—' %></td>
            <td><%= n.masa_tahanan || '—' %></td>
            <td class="num"><%= n.umur || '—' %></td>
            <td>
              <div class="aksi-group">
                <button type="button" class="icon-btn view" title="Lihat" aria-label="Lihat" data-modal-open="view-narapidana-<%= n.id %>"><%- include('../partials/icon-eye') %></button>
                <a href="/koordinator/narapidana/<%= n.id %>/edit" class="icon-btn edit" title="Ubah" aria-label="Ubah"><%- include('../partials/icon-edit') %></a>
                <form action="/koordinator/narapidana/<%= n.id %>/delete" method="POST" onsubmit="return confirm('Hapus data narapidana ini? Data penilaian terkait juga akan terhapus.');">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="icon-btn delete" title="Hapus" aria-label="Hapus"><%- include('../partials/icon-trash') %></button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <% narapidana.forEach(n => { %>
    <div class="modal-overlay" id="view-narapidana-<%= n.id %>">
      <div class="modal-box">
        <div class="modal-head">
          <h3><%= n.nama %></h3>
          <button type="button" class="modal-close" data-modal-close aria-label="Tutup">&times;</button>
        </div>
        <div class="modal-body">
          <dl class="detail-list">
            <dt>Wali Pembina</dt><dd><%= n.wali_nama %></dd>
            <dt>Agama</dt><dd><%= n.agama || '—' %></dd>
            <dt>Tempat, Tgl Lahir</dt><dd><%= n.tempat_lahir || '—' %>, <%= n.tanggal_lahir || '—' %></dd>
            <dt>Umur</dt><dd><%= n.umur || '—' %></dd>
            <dt>Alamat</dt><dd><%= n.alamat || '—' %></dd>
            <dt>Pendidikan Terakhir</dt><dd><%= n.pendidikan_terakhir || '—' %></dd>
            <dt>Nomor KTP</dt><dd><%= n.nomor_ktp || '—' %></dd>
            <dt>Kategori Register</dt><dd><%= n.kategori_register || '—' %></dd>
            <dt>Tindak Pidana</dt><dd><%= n.tindak_pidana_jenis || '—' %> <% if (n.pasal_kuhp) { %>(<%= n.pasal_kuhp %>)<% } %></dd>
            <dt>Pekerjaan Semula</dt><dd><%= n.pekerjaan_semula || '—' %></dd>
            <dt>Masa Tahanan</dt><dd><%= n.masa_tahanan || '—' %></dd>
          </dl>
        </div>
        <div class="modal-foot">
          <a href="/koordinator/narapidana/<%= n.id %>/edit" class="btn btn-accent btn-sm">Ubah Data</a>
        </div>
      </div>
    </div>
  <% }) %>
<% } %>

<%- include('../partials/footer') %>
